---
import NavHeader from "@components/navigation/nav-header/NavHeader";
import type { ActiveNav } from "@components/navigation/nav-header/types";

export interface Props {
  activeNav?: ActiveNav;
  hidden?: boolean;
}

const { activeNav, hidden = false } = Astro.props;
---

<header class="site-header">
  <div
    id="nav-header-container"
    transition:persist="nav-header"
    transition:animate="none"
    data-nav-visible={hidden ? "false" : "true"}
    style={`opacity:${hidden ? "0" : "1"};transition:none;`}
  >
    <NavHeader client:load activeNav={activeNav} hidden={hidden} />
  </div>
</header>

{/* 현재 페이지의 hidden 상태를 전역에 저장 (persist된 요소에서 읽을 수 있도록) */}
<script is:inline define:vars={{ hidden }}>
  window.__navHidden = hidden;
</script>

{/* 페이지 전환 후 hidden 상태 동기화 */}
<script>
  function getNavContainer() {
    return document.getElementById("nav-header-container");
  }

  function setNavVisibility({ hidden, animate }) {
    const container = getNavContainer();
    if (!container) return;

    const wasVisible = container.dataset.navVisible !== "false";
    container.style.transition = animate ? "opacity 0.4s ease-out" : "none";

    if (hidden) {
      container.dataset.navVisible = "false";
      if (wasVisible) {
        container.style.opacity = "0";
      }
      return;
    }

    container.dataset.navVisible = "true";

    if (!wasVisible && animate) {
      setTimeout(() => {
        const nextContainer = getNavContainer();
        if (!nextContainer) return;
        nextContainer.style.opacity = "1";
      }, 50);
      return;
    }

    container.style.opacity = "1";
  }

  function syncNavVisibility() {
    setNavVisibility({
      hidden: (window as any).__navHidden,
      animate: true,
    });
  }

  // 초기 로드
  document.addEventListener('astro:page-load', syncNavVisibility);
</script>

<style>
  .site-header {
    position: relative;
    z-index: 30;
  }
</style>
