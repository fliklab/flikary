    summary: "인용 preview를 가볍게 넣을지, 더 또렷하게 구분할지 비교한다.",
    cards: [
      {
        title: "가벼운 인용",
        date: "2일 전",
        body: ["원문이 메모보다 앞에 나오지 않도록 인용은 한 단계 낮게 두는 안이다."],
        quote: {
          title: "협업에서 가장 중요한 것은 목표의 동기화이다",
          description: "톤이 가벼운 preview",
        },
      },
      {
        title: "강한 인용",
        date: "2일 전",
        body: ["메모의 짧은 코멘트와 인용을 더 명확히 구분하는 안이다."],
        quote: {
          title: "협업에서 가장 중요한 것은 목표의 동기화이다",
          description: "톤이 더 강한 preview",
          strong: true,
        },
      },
    ],
  },
];

const navPairs = [
  {
    name: "NV-1",
    note: "가장 현재 구조에 가까운 기본형",
    expanded: {
      leftIcon: IconBack,
      menus: [
        { label: "Feed" },
        { label: "Blog" },
        { label: "About" },
      ],
      icons: [IconHome, IconArchive, IconSearch, IconTheme, IconGitHub],
    },
    compact: [IconBack, IconHome, IconBook, IconBadge, IconArchive, IconSearch, IconTheme, IconGitHub],
  },
  {
    name: "NV-2",
    note: "텍스트 메뉴를 두 개로 줄이고 우측 아이콘 비중을 키운 안",
    expanded: {
      leftIcon: IconBack,
      menus: [
        { label: "Feed" },
        { label: "Blog" },
      ],
      icons: [IconBadge, IconHome, IconArchive, IconSearch, IconTheme, IconGitHub],
    },
    compact: [IconBack, IconHome, IconBook, IconBadge, IconArchive, IconSearch, IconTheme, IconGitHub],
  },
  {
    name: "NV-3",
    note: "좌측에 대표 메뉴, 우측에 유틸 아이콘만 남기는 안",
    expanded: {
      leftIcon: IconBack,
      menus: [
        { label: "Feed" },
        { label: "Blog" },
        { label: "About" },
      ],
      icons: [IconArchive, IconSearch, IconTheme, IconGitHub],
    },
    compact: [IconBack, IconHome, IconBook, IconBadge, IconArchive, IconSearch, IconTheme, IconGitHub],
  },
  {
    name: "NV-4",
    note: "펼침 상태에서 메뉴 옆에도 아이콘을 붙여 읽게 하는 안",
    expanded: {
      leftIcon: IconBack,
      menus: [
        { label: "Feed", Icon: IconHome },
        { label: "Blog", Icon: IconBook },
        { label: "About", Icon: IconBadge },
      ],
      icons: [IconArchive, IconSearch, IconTheme, IconGitHub],
    },
    compact: [IconBack, IconHome, IconBook, IconBadge, IconArchive, IconSearch, IconTheme, IconGitHub],
  },
  {
    name: "NV-5",
    note: "축소 상태 8개를 탐색 4개와 유틸 4개로 읽게 하는 안",
    expanded: {
      leftIcon: IconBack,
      menus: [
        { label: "Feed" },
        { label: "Blog" },
        { label: "About" },
      ],
      icons: [IconArchive, IconSearch, IconTheme, IconGitHub],
    },
    compact: [IconHome, IconBook, IconBadge, IconBack, IconArchive, IconSearch, IconTheme, IconGitHub],
  },
];
---

<Layout
  title={`Design Demo | ${SITE.title}`}
  description="Feed 디자인 시안 비교"
  forceRobotsNoindex
>
  <Header />

  <main id="main-content" class="design-demo-page">
    <header class="page-header">
      <h1>Feed Design Demo</h1>
      <p>B안을 기준으로 제목이 없는 경우, 인용이 있는 경우, 짧은 메모와 긴 본문까지 함께 비교하는 비기능 시안.</p>
    </header>

    <section class="variant-block" aria-labelledby="nav-desktop">
      <header class="variant-header">
        <span class="variant-label">Desktop Nav</span>
        <h2 id="nav-desktop">데스크톱 네비게이션 배치 후보</h2>
        <p>실제 스타일 변경 없이, 펼침 상태와 축소 상태를 한 쌍으로 두고 메뉴와 아이콘 배치만 비교하는 시안.</p>
      </header>

      <div class="nav-pair-list">
        {navPairs.map(pair => (
          <section class="nav-pair-card">
            <div class="card-preview-meta">
              <span class="card-variant-name">{pair.name}</span>
              <span class="card-variant-note">{pair.note}</span>
            </div>

            <div class="nav-pair-stack">
              <div class="nav-demo-row">
                <span class="nav-demo-label">Expanded</span>
                <div class="nav-demo-surface nav-demo-surface-expanded">
                  <div class="nav-demo-left">
                    <span class="nav-demo-icon-button" aria-hidden="true">
                      <pair.expanded.leftIcon />
                    </span>

                    <div class="nav-demo-menu-group">
                      {pair.expanded.menus.map(menu => (
                        <span class="nav-demo-menu-item">
                          {menu.Icon && (
                            <span class="nav-demo-menu-icon" aria-hidden="true">
                              <menu.Icon />
                            </span>
                          )}
                          <span>{menu.label}</span>
                        </span>
                      ))}
                    </div>
                  </div>

                  <div class="nav-demo-icon-group">
                    {pair.expanded.icons.map(Icon => (
                      <span class="nav-demo-icon-button" aria-hidden="true">
                        <Icon />
                      </span>
                    ))}
                  </div>
                </div>
              </div>

              <div class="nav-demo-row">
                <span class="nav-demo-label">Compact</span>
                <div class="nav-demo-surface nav-demo-surface-compact">
                  <div class="nav-demo-icon-group nav-demo-icon-group-compact">
                    {pair.compact.map(Icon => (
                      <span class="nav-demo-icon-button" aria-hidden="true">
                        <Icon />
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="variant-block" aria-labelledby="bn-primary">
      <header class="variant-header">
        <span class="variant-label">New</span>
        <h2 id="bn-primary">BN안. 기본 컴포넌트 + series</h2>
        <p>`BN-1`을 기본 컴포넌트로 두고, 제목 유무, 본문 길이, 인용 유무만 달라지는 variation을 같은 구조 안에서 비교한다.</p>
      </header>

      <div class="card-stack card-stack-primary">
        {bnCards.map(card => (
          <div class="card-preview">
            <div class="card-preview-meta">
              <span class="card-variant-name">{card.name}</span>
              <span class="card-variant-note">{card.note}</span>
            </div>

            <article class="demo-card">
              <div class="bn-header-row">
                <div class="bn-title-block">
                  {card.title && <h3 class="card-title">{card.title}</h3>}
                  <p class="card-date">{card.date}</p>
                </div>

                <span class="bn-series">{card.series}</span>
              </div>

              <div class="card-body">
                {card.body.map(line => (
                  <p>{line}</p>
                ))}
              </div>

              {card.more && <a href="#" class="more-link">...더보기</a>}

              {card.quote && (
                <section class:list={["quote-card", card.quote.strong && "quote-card-strong"]}>
                  {card.quote.image ? (
                    <div class="quote-content-row">
                      <div class="quote-copy">
                        <h4>{card.quote.title}</h4>
                        <p>{card.quote.description}</p>
                      </div>
                      <div class="quote-image">
                        <img src={card.quote.image} alt="" loading="lazy" />
                      </div>
                    </div>
                  ) : (
                    <>
                      <h4>{card.quote.title}</h4>
                      <p>{card.quote.description}</p>
                    </>
                  )}
                </section>
              )}

              {card.tags && (
                <ul class="tag-list" aria-label="태그">
                  {card.tags.map(tag => (
                    <li>#{tag}</li>
                  ))}
                </ul>
              )}
            </article>
          </div>
        ))}
      </div>
    </section>

    <section class="variant-block" aria-labelledby="b-primary">
      <header class="variant-header">
        <span class="variant-label">Selected</span>
        <h2 id="b-primary">B안. 제목 위, 날짜 아래</h2>
        <p>글 카드에 가까운 위계를 유지하되, 제목이 없는 메모와 인용형 카드도 같은 컴포넌트 구조 안에 들어갈 수 있어야 한다.</p>
      </header>

      <div class="card-stack card-stack-primary">
        {primaryCards.map(card => (
          <div class="card-preview">
            <div class="card-preview-meta">
              <span class="card-variant-name">{card.name}</span>
              <span class="card-variant-note">{card.note}</span>
            </div>

            <article class="demo-card">
              {card.title && (
                <h3 class:list={["card-title", card.titleTone === "b1" && "card-title-b1"]}>
                  {card.title}
                </h3>
              )}

              <p class="card-date">{card.date}</p>

              <div class="card-body">
                {card.body.map(line => (
                  <p>{line}</p>
                ))}
              </div>

              {card.fromText && <p class="card-from-text">{card.fromText}</p>}

              {card.quote && (
                <section class:list={["quote-card", card.quote.strong && "quote-card-strong"]}>
                  {card.quote.image ? (
                    <div class="quote-content-row">
                      <div class="quote-copy">
                        <h4>{card.quote.title}</h4>
                        <p>{card.quote.description}</p>
                      </div>
                      <div class="quote-image">
                        <img src={card.quote.image} alt="" loading="lazy" />
                      </div>
                    </div>
                  ) : (
                    <>
                      <h4>{card.quote.title}</h4>
                      <p>{card.quote.description}</p>
                    </>
                  )}
                </section>
              )}

              {card.more && <a href="#" class="more-link">...더보기</a>}

              {card.tags && (
                <ul class="tag-list" aria-label="태그">
                  {card.tags.map(tag => (
                    <li>#{tag}</li>
                  ))}
                </ul>
              )}
            </article>
          </div>
        ))}
      </div>
    </section>

    <section class="variant-block" aria-labelledby="bx-primary">
      <header class="variant-header">
        <span class="variant-label">Experiment</span>
        <h2 id="bx-primary">BX안. 카드 바깥 메타 + 상단 첫 줄 치환</h2>
        <p>`B-4`, `기본형`, `긴 본문` 같은 비교 라벨은 카드 밖으로 빼고, 그 자리에 날짜나 제목이 들어갔을 때의 인상을 비교한다.</p>
      </header>

      <div class="card-stack card-stack-primary">
        {bxCards.map(card => (
          <div class="card-preview">
            <div class="card-preview-meta">
              <span class="card-variant-name">{card.name}</span>
              <span class="card-variant-note">{card.note}</span>
            </div>

            <article class="demo-card">
              {card.layout === "combined-meta" ? (
                <div class="card-combined-meta">
                  <div class="card-combined-main">
                    <h3 class="card-title card-title-b1">{card.topLeft}</h3>
                    {card.date && <p class="card-date card-combined-date">{card.date}</p>}
                  </div>

                  <div class="card-combined-side">
                    {card.series && <span class="card-combined-item">{card.series}</span>}
                  </div>
                </div>
              ) : (
                <>
                  <div class="card-topline-row">
                    <p class="card-topline">{card.topLeft}</p>
                    {(card.series || card.topRight) && (
                      <p class="card-topline-right">{card.series ?? card.topRight}</p>
                    )}
                  </div>

                  {card.title && <h3 class="card-title">{card.title}</h3>}
                  {card.date && <p class="card-date">{card.date}</p>}
                </>
              )}

              <div class="card-body">
                {card.body.map(line => (
                  <p>{line}</p>
                ))}
              </div>

              {card.fromText && <p class="card-from-text">{card.fromText}</p>}

              {card.quote && (
                <section class:list={["quote-card", card.quote.strong && "quote-card-strong"]}>
                  <h4>{card.quote.title}</h4>
                  <p>{card.quote.description}</p>
                </section>
              )}

              {card.more && <a href="#" class="more-link">...더보기</a>}

              {card.tags && (
                <ul class="tag-list" aria-label="태그">
                  {card.tags.map(tag => (
                    <li>#{tag}</li>
                  ))}
                </ul>
              )}
            </article>
          </div>
        ))}
      </div>
    </section>

    <div class="comparison-list">
      {secondaryComparisons.map(group => (
        <section class="variant-block" aria-labelledby={`group-${group.id}`}>
          <header class="variant-header">
            <span class="variant-label">Comparison</span>
            <h2 id={`group-${group.id}`}>{group.title}</h2>
            <p>{group.summary}</p>
          </header>

          <div class="card-stack">
            {group.cards.map(card => (
              <article class="demo-card">
                {card.title && (
                  <h3 class:list={["card-title", card.titleTone === "b1" && "card-title-b1"]}>
                    {card.title}
                  </h3>
                )}
                <p class="card-date">{card.date}</p>

                <div class="card-body">
                  {card.body.map(line => (
                    <p>{line}</p>
                  ))}
                </div>

                {card.fromText && <p class="card-from-text">{card.fromText}</p>}

                {card.quote && (
                  <section class:list={["quote-card", card.quote.strong && "quote-card-strong"]}>
                    {card.quote.image ? (
                      <div class="quote-content-row">
                        <div class="quote-copy">
                          <h4>{card.quote.title}</h4>
                          <p>{card.quote.description}</p>
                        </div>
                        <div class="quote-image">
                          <img src={card.quote.image} alt="" loading="lazy" />
                        </div>
                      </div>
                    ) : (
                      <>
                        <h4>{card.quote.title}</h4>
                        <p>{card.quote.description}</p>
                      </>
                    )}
                  </section>
                )}

                {card.more && <a href="#" class="more-link">...더보기</a>}

                {card.tags && (
                  <ul class="tag-list" aria-label="태그">
                    {card.tags.map(tag => (
                      <li>#{tag}</li>
                    ))}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .design-demo-page {
    width: min(92vw, 70rem);
    margin: 0 auto;
    padding: 0 1rem 4rem;
  }

  .page-header {
    padding: 1.5rem 0 2rem;
  }

  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 7vw, 4.2rem);
    letter-spacing: -0.04em;
    line-height: 0.96;
  }

  .page-header p {
    margin-top: 0.7rem;
    font-size: 1rem;
    color: rgba(var(--color-text-base), 0.62);
    max-width: 45rem;
    line-height: 1.7;
  }

  .comparison-list {
    display: grid;
    gap: 2.5rem;
    margin-top: 2.5rem;
  }

  .nav-pair-list {
    display: grid;
    gap: 1rem;
  }

  .nav-pair-card {
    display: grid;
    gap: 0.55rem;
  }

  .nav-pair-stack {
    display: grid;
    gap: 0.8rem;
    border: 1px solid rgba(var(--color-border), 0.56);
    border-radius: 1.5rem;
    padding: 1.2rem;
    background: rgba(var(--color-bg-base), 0.76);
    box-shadow: 0 14px 38px rgba(35, 25, 18, 0.05);
  }

  :root[data-theme="dark"] .nav-pair-stack {
    background: rgba(26, 24, 22, 0.92);
    box-shadow: 0 14px 38px rgba(0, 0, 0, 0.18);
  }

  .nav-demo-row {
    display: grid;
    gap: 0.45rem;
  }

  .nav-demo-label {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--color-text-base), 0.45);
  }

  .nav-demo-surface {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    min-width: 0;
    border: 1px solid rgba(var(--color-border), 0.68);
    border-radius: 999px;
    padding: 0.5rem 0.7rem;
    background: rgba(var(--color-bg-base), 0.9);
  }

  .nav-demo-surface-expanded {
    width: min(100%, 42rem);
  }

  .nav-demo-surface-compact {
    width: min(100%, 22rem);
  }

  .nav-demo-left {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
  }

  .nav-demo-menu-group,
  .nav-demo-icon-group {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
  }

  .nav-demo-icon-group-compact {
    width: 100%;
    justify-content: space-between;
  }

  .nav-demo-menu-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.72rem;
    border-radius: 999px;
    font-size: 0.95rem;
    line-height: 1;
    color: rgba(var(--color-text-base), 0.84);
  }

  .nav-demo-menu-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(var(--color-text-base), 0.72);
  }

  .nav-demo-icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    color: rgba(var(--color-text-base), 0.72);
  }

  .variant-block {
    display: grid;
    gap: 1rem;
  }

  .variant-header {
    display: grid;
    gap: 0.35rem;
  }

  .variant-label {
    display: inline-flex;
    width: fit-content;
    border-radius: 999px;
    border: 1px solid rgba(var(--color-border), 0.65);
    padding: 0.24rem 0.62rem;
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(var(--color-text-base), 0.6);
  }

  .variant-header h2 {
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    letter-spacing: -0.03em;
  }

  .variant-header p {
    color: rgba(var(--color-text-base), 0.64);
    line-height: 1.7;
    max-width: 50rem;
  }

  .card-stack {
    display: grid;
    gap: 1rem;
  }

  .card-stack-primary {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .bn-header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    min-width: 0;
  }

  .bn-title-block {
    display: grid;
    gap: 0.9rem;
    min-width: 0;
  }

  .bn-series {
    flex-shrink: 0;
    text-align: right;
    justify-content: flex-end;
    font-size: 0.88rem;
    line-height: 1.45;
    color: rgba(var(--color-text-base), 0.48);
  }

  .card-preview {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .card-preview-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    min-width: 0;
    padding: 0 0.2rem;
    color: rgba(var(--color-text-base), 0.45);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .demo-card {
    display: grid;
    gap: 0.9rem;
    min-width: 0;
    border: 1px solid rgba(var(--color-border), 0.56);
    border-radius: 1.5rem;
    padding: 1.35rem 1.35rem 1.2rem;
    background: rgba(var(--color-bg-base), 0.76);
    box-shadow: 0 14px 38px rgba(35, 25, 18, 0.05);
  }

  :root[data-theme="dark"] .demo-card {
    background: rgba(26, 24, 22, 0.92);
    box-shadow: 0 14px 38px rgba(0, 0, 0, 0.18);
  }

  .card-date,
  .more-link,
  .quote-label {
    font-size: 0.88rem;
    color: rgba(var(--color-text-base), 0.48);
  }

  .card-from-text {
    justify-self: end;
    text-align: right;
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgba(var(--color-text-base), 0.58);
  }

  .card-topline {
    font-size: 0.95rem;
    color: rgba(var(--color-text-base), 0.6);
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  .card-topline-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.9rem;
    min-width: 0;
  }

  .card-topline-right {
    flex-shrink: 0;
    font-size: 0.85rem;
    line-height: 1.45;
    color: rgba(var(--color-text-base), 0.46);
    text-align: right;
  }

  .card-combined-meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    min-width: 0;
  }

  .card-combined-main {
    display: grid;
    gap: 0;
    min-width: 0;
  }

