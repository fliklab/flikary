---
import Layout from "@layouts/Layout.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import FeedItem from "@components/feed/FeedItem.astro";
import type { FeedItemViewModel } from "@utils/content/feed";
import { SITE } from "@config";

export interface Props {
  items: FeedItemViewModel[];
}

const { items } = Astro.props;
---

<Layout
  title={`Feed | ${SITE.title}`}
  description="생각과 메모를 짧게 쌓아두는 기록 피드."
  forceRobotsNoindex
>
  <Header activeNav="feed" />

  <main id="main-content" class="feed-page">
    <header class="feed-header">
      <h1>feed</h1>
      <p>짧은 생각과 메모를 이어 붙이는 흐름.</p>
    </header>

    <section class="feed-stream">
      {items.map(item => <FeedItem item={item} />)}
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .feed-page {
    max-width: min(92vw, 46rem);
    margin: 0 auto;
    padding: 0 1rem 4rem;
  }

  .feed-header {
    padding: 1.25rem 0 1.75rem;
  }

  .feed-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    line-height: 1.05;
  }

  .feed-header p {
    margin-top: 0.55rem;
    color: rgba(var(--color-text-base), 0.58);
  }
 </style>
